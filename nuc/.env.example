# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_GROUP_ID=your_group_chat_id_here  # negative number, e.g. -1001234567890

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# VPS connection
VPS_WEBHOOK_URL=https://recepten.example.com/api/push
VPS_SHARED_SECRET=generate_with_openssl_rand_hex_32

# Optional overrides
PROPOSAL_DAY=1        # 0=Mon, 1=Tue
PROPOSAL_HOUR=9
REMINDER_HOUR=18
SHOPPING_REMINDER_HOUR=14
